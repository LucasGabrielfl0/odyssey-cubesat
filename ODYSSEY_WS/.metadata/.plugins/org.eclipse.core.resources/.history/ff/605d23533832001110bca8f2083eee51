#include "E220_900T22D.h"

// Wait for AUX to go HIGH (module ready)
static void LoRa_WaitAux(void) {
    while (HAL_GPIO_ReadPin(LORA_AUX_PORT, LORA_AUX_PIN) == GPIO_PIN_RESET);
    HAL_Delay(10);
}

// Enter config mode (M0=1, M1=1) ----------------------------------------
static void LoRa_EnterConfigMode(void) {
    HAL_GPIO_WritePin(LORA_M0_PORT, LORA_M0_PIN, GPIO_PIN_SET);
    HAL_GPIO_WritePin(LORA_M1_PORT, LORA_M1_PIN, GPIO_PIN_SET);
    HAL_Delay(100);
    LoRa_WaitAux();
}

// Return to normal mode (M0=0, M1=0) ------------------------------------------------------------
static void LoRa_EnterNormalMode(void) {
    HAL_GPIO_WritePin(LORA_M0_PORT, LORA_M0_PIN, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(LORA_M1_PORT, LORA_M1_PIN, GPIO_PIN_RESET);
    HAL_Delay(100);
    LoRa_WaitAux();
}

void LoRa_Configure(UART_HandleTypeDef *huart) {
    LoRa_EnterConfigMode();

    uint8_t config[9];
    config[0] = 0xC0;   // Write + save to flash
    config[1] = 0x00;   // Start register address
    config[2] = 0x06;   // Number of registers to write

    config[3] = 0x00;   // ADDH [SET, BUT NOT USED]
    config[4] = 0x00;   // ADDL [SET, BUT NOT USED]
    config[5] = 0xE7;   // SPED: 115200 baud | 8N1 | 9.6kbps air
    config[6] = 0x03;   // OPTION: 240 byte packet | 22dBm
    config[7] = 0x12;   // CHAN: channel 18
    config[8] = 0x00;   // TRANS: transparent | no RSSI | no LBT

    // In config mode, BaudRate is aways 9600
    huart.Init.BaudRate = 9600;
    HAL_UART_Transmit(huart, config, 9, HAL_MAX_DELAY);
    HAL_Delay(100);

    // Stops Until Aux confirms changes
    LoRa_WaitAux();

    // Read back confirmation (module echoes config)
    uint8_t response[9];
    HAL_UART_Receive(huart, response, 9, 1000);

    HAL_Delay(60000);

    // Switch UART to 115200 for normal operation
    huart->Init.BaudRate = 115200;
    HAL_UART_Init(huart);
}
